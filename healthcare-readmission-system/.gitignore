.npm
*.log

# Data (large files — keep structure, not raw downloads)
data/raw/*.csv
data/raw/*.zip
data/processed/*.csv
data/processed/*.parquet
!data/raw/.gitkeep
!data/processed/.gitkeep

# Models (trained artifacts)
models/*.pkl
models/*.joblib
models/*.json
!models/.gitkeep

# Environment & secrets
.env
.env.local
*.pem

# IDE & OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Power BI
dashboard/*.pbix
